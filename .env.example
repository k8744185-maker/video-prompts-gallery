# ─────────────────────────────────────────────────────────────
# .env.example — Copy this to .env and fill in your real values.
# NEVER commit .env to GitHub. This file is safe to commit.
# ─────────────────────────────────────────────────────────────

# Google Sheets
GOOGLE_SHEET_ID=your_google_sheet_id_here
GOOGLE_CREDENTIALS={"type":"service_account","project_id":"..."}

# Flask security key (generate: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=generate_a_random_secret_key_here

# Encryption key for API keys stored in Sheets
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=generate_a_fernet_key_here

# Admin panel password — use a strong password, not 'admin123'
ADMIN_PASSWORD=your_strong_password_here

# Cloudinary — for persistent image uploads
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Gemini AI (optional)
GEMINI_API_KEY=your_gemini_api_key

# OpenAI (optional)
OPENAI_API_KEY=your_openai_api_key
